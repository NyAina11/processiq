# =====================================================
# PROCESS IQ — Variables d'environnement VPS
# Copier ce fichier en .env et remplir les valeurs
# =====================================================

# IP publique du VPS (ex: 192.168.1.1)
VPS_IP=<VPS_IP>

# CORS — Origins autorisées (mettre http://<VPS_IP> en prod)
CORS_ORIGIN=*

# --- AIRTABLE ---
AIRTABLE_API_TOKEN=<votre_token_airtable>
AIRTABLE_BASE_ID=<votre_base_id>

# --- AUTH ---
JWT_SECRET=<une_chaine_secrete_aleatoire>

# --- LOGGING ---
LOG_LEVEL=info
