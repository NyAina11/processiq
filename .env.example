# =====================================================
# PROCESS IQ — Variables d'environnement VPS
# Copier ce fichier en .env et remplir les valeurs
# =====================================================

# IP publique du VPS (ex: 192.168.1.1)
VPS_IP=<VPS_IP>

# --- CORS (mettre l'URL HTTPS du domaine en prod) ---
CORS_ORIGIN=https://process1q.duckdns.org

# --- AUTH ---
JWT_SECRET=<une_chaine_secrete_aleatoire>

# --- LOGGING ---
LOG_LEVEL=info

# --- MONGODB ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=ProcessIQ
DB_NAME=processiq

# --- UPLOADS ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
PUBLIC_BASE_URL=

# --- DEFAULT USERS ---
DEFAULT_USERS_SYNC_PASSWORDS=true
DEFAULT_ADMIN_PASSWORD=<admin_password>
DEFAULT_ADMISSION_PASSWORD=<admission_password>
DEFAULT_COMMERCIAL_PASSWORD=<commercial_password>
DEFAULT_RH_PASSWORD=<rh_password>
DEFAULT_ELEVE_PASSWORD=<eleve_password>
DEFAULT_ADMISSION_1_EMAIL=admission1@rush-school.fr
DEFAULT_ADMISSION_1_PASSWORD=<password>
DEFAULT_ADMISSION_1_NAME=Admission 1
DEFAULT_ADMISSION_2_EMAIL=admission2@rush-school.fr
DEFAULT_ADMISSION_2_PASSWORD=<password>
DEFAULT_ADMISSION_2_NAME=Admission 2
DEFAULT_ADMISSION_MANAGER_EMAIL=responsable.admission@rush-school.fr
DEFAULT_ADMISSION_MANAGER_PASSWORD=<password>
DEFAULT_ADMISSION_MANAGER_NAME=Responsable Admission

# --- DOCUSIGN ---
DOCUSIGN_ENABLED=true
DOCUSIGN_INTEGRATION_KEY=<integration_key>
DOCUSIGN_USER_ID=<user_id>
DOCUSIGN_ACCOUNT_ID=<account_id>
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_RETURN_URL=https://process1q.duckdns.org/retour-signature
DOCUSIGN_PRIVATE_KEY_FILE=./secrets/docusign-private.pem
DOCUSIGN_SCOPES=signature impersonation
DOCUSIGN_WEBHOOK_SECRET=<webhook_secret>

# =====================================================
# HTTPS — Let's Encrypt + DuckDNS
# =====================================================

# Domaine DuckDNS pointant vers le VPS
DOMAIN=process1q.duckdns.org

# Token DuckDNS (visible sur https://www.duckdns.org/ après connexion)
DUCKDNS_TOKEN=<votre_token_duckdns>

# Email utilisé pour Let's Encrypt (notifications d'expiration)
CERTBOT_EMAIL=<votre_email>
